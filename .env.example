# Banco de dados
DATABASE_URL="postgresql://user:password@localhost:5432/mobilador"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Google OAuth (para login)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# YouTube API
YOUTUBE_API_KEY="your-youtube-api-key"
YOUTUBE_CHANNEL_ID="your-channel-id"

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN="your-mercadopago-token"

# Site URL (mude para seu domínio após compra)
NEXT_PUBLIC_SITE_URL="https://mobilador-site.vercel.app"
# NEXT_PUBLIC_SITE_URL="https://jcgamerfps.com.br"

# APK Download (Google Drive link direto)
NEXT_PUBLIC_APK_DOWNLOAD_LINK="https://drive.google.com/file/d/SEU_ID_DO_ARQUIVO/view"

# Meta Pixel
META_PIXEL_ID="your-meta-pixel-id"
