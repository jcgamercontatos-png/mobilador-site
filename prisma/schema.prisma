generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  orders    Order[]
  reviews   Review[]
  comments  Comment[]
  communityProfiles CommunityProfile[]
  enrollments      Enrollment[]
  packPurchases    PackPurchase[]
  stockMovements   StockMovement[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
  MODERATOR
}

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String
  price         Float
  originalPrice Float?
  category      String
  subcategory   String?
  images        String[]
  badge         String?
  stock         Int      @default(0)
  featured      Boolean  @default(false)
  active        Boolean  @default(true)
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orderItems     OrderItem[]
  reviews        Review[]
  stockMovements StockMovement[]
  skus           ProductSKU[]
}

model ProductSKU {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku       String   @unique
  name      String
  price     Float
  stock     Int      @default(0)
  attributes Json?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]

  @@index([productId])
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  status        OrderStatus @default(PENDING)
  total         Float
  paymentMethod String?
  paymentId     String?
  couponCode    String?
  discount      Float       @default(0)
  stockDeducted Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user  User        @relation(fields: [userId], references: [id])
  items OrderItem[]
  stockMovements StockMovement[]
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model OrderItem {
  id        String     @id @default(cuid())
  orderId   String
  productId String
  skuId     String?
  quantity  Int
  price     Float

  order   Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product    @relation(fields: [productId], references: [id])
  sku     ProductSKU? @relation(fields: [skuId], references: [id])
}

model Course {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  price       Float
  originalPrice Float?
  image       String?
  features    String[]
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enrollments Enrollment[]
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  progress  Float    @default(0)
  completed Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

model Pack {
  id            String   @id @default(cuid())
  name          String
  description   String
  price         Float
  originalPrice Float?
  contents      String[]
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  purchases PackPurchase[]
}

model PackPurchase {
  id        String   @id @default(cuid())
  userId    String
  packId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  pack Pack @relation(fields: [packId], references: [id])

  @@unique([userId, packId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  category    String
  tags        String[]
  image       String?
  published   Boolean  @default(false)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([postId])
}

model StockMovement {
  id               String   @id @default(cuid())
  productId        String
  quantidadeAnterior Int
  quantidadeAlterada Int
  quantidadeFinal    Int
  motivo           String
  pedidoId         String?
  usuarioAdminId   String?
  createdAt        DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [usuarioAdminId], references: [id])
  order   Order?  @relation(fields: [pedidoId], references: [id])

  @@index([productId])
  @@index([createdAt])
}

model CommunityProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  username    String   @unique
  bio         String?
  device      String?
  dpi         Int?
  playStyle   String?
  rank        String?
  points      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([points(sort: Desc)])
}

model NewsletterSubscription {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model License {
  id            String    @id @default(cuid())
  username      String    @unique
  password      String
  displayName   String?
  licenseType   String    @default("permanent")
  licenseDays   Int       @default(0)
  licenseStart  DateTime?
  deviceId      String?
  isValid       Boolean   @default(true)
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model SensitivityConfig {
  id            String  @id @default(cuid())
  device        String
  dpi           Int
  screenSize    Float
  fps           Int
  playStyle     String
  general       Float
  redDot        Float
  scope2x       Float
  scope4x       Float
  freeLook      Float
  createdAt     DateTime @default(now())

  @@index([device])
}
